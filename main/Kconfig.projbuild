menu "PrintSpy Cam Configuration"

    choice PRINTSPY_CAM_BOARD
        prompt "Target board"
        default BOARD_FREENOVE_S3

        config BOARD_FREENOVE_S3
            bool "Freenove ESP32-S3 CAM"
            depends on IDF_TARGET_ESP32S3

        config BOARD_NULLLAB_ESP32S3_CAM
            bool "nulllaborg ESP32-S3-CAM"
            depends on IDF_TARGET_ESP32S3

    endchoice

endmenu
